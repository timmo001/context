{
  "name": "context",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "context": "./dist/context"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/context",
    "test": "bun test",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"docs/astro.config.mjs\" \"docs/scripts/**/*.{ts,mjs}\" \"docs/src/**/*.{md,mdx,astro,css}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"docs/astro.config.mjs\" \"docs/scripts/**/*.{ts,mjs}\" \"docs/src/**/*.{md,mdx,astro,css}\"",
    "prepare": "effect-language-service patch"
  },
  "dependencies": {
    "@effect/platform-node": "^4.0.0-beta.93",
    "effect": "^4.0.0-beta.93"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.4",
    "@types/bun": "^1.3.13",
    "prettier": "^3.5.3",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@effect/language-service"
  ]
}
